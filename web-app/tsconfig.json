{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    // Off because web-app now compiles the shared ../components/primitives +
    // ../lib library (authored under the Expo app's looser rules — unused React
    // imports under the classic runtime, etc.). web-app's own src is still
    // guarded for unused vars by eslint (npm run lint).
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"], "@root/*": ["../*"] },
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["src/__tests__", "vitest.config.ts"]
}
