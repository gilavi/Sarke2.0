node_modules/
.expo/
.expo-shared/
dist/
*.log
.DS_Store
.env
.env.local
.env.*.local
.claude/

# Local prod schema dumps used during staging setup — never commit (large,
# prod-derived). See docs/STAGING_SETUP_LOG.md.
supabase/baseline_prod_schema.sql
supabase/prod_storage_*.sql

# Native build output from `expo prebuild` / `expo run:ios|android`.
# This is a managed Expo project — native dirs regenerate on demand
# and shouldn't be tracked.
ios/
android/

# Local Supabase CLI state (project ref, version cache). Generated on
# `supabase link`; not source.
supabase/.temp/

# Docusaurus build artefacts (the gh-pages workflow rebuilds on push).
website/build/
website/.docusaurus/
website/.cache-loader/

# Playwright test artefacts
playwright-report/
test-results/

# Vitest coverage output (regenerated on `npx vitest run --coverage`)
coverage/
