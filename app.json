{
  "expo": {
    "name": "Sarke",
    "slug": "sarke2",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sarke",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F2EA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "ge.sarke.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "კამერა გამოიყენება ხარაჩოს და ქამრების ფოტოების ატვირთვისთვის.",
        "NSPhotoLibraryUsageDescription": "ფოტოების არჩევა სისტემის ბიბლიოთეკიდან.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6F2EA"
      },
      "package": "ge.sarke.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "აპი ითხოვს წვდომას გალერეაზე ფოტოების ასატვირთად.",
          "cameraPermission": "კამერა გამოიყენება ფოტოების გადასაღებად."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#147A4F"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "supabaseUrl": "https://seskuthiopywrgntsgfw.supabase.co",
      "supabaseAnonKey": "sb_publishable_OF_L2E27-Uv8MMw87fWfSA_znD7moYY",
      "googleIosClientId": "",
      "googleAndroidClientId": "",
      "googleWebClientId": "",
      "useMockData": false,
      "router": {},
      "eas": {
        "projectId": "c50f3e11-27fb-4477-ba82-13df9179134f"
      }
    },
    "experiments": {
      "typedRoutes": false
    },
    "owner": "gilavi2000"
  }
}
