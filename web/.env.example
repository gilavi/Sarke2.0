# Copy to `.env.local` and fill in. Build-time-only — `VITE_` prefix exposes
# them to the bundle. Both are required.
#
# Anon key is safe to ship in a public bundle: it's the same key the mobile
# app uses, RLS still applies, and our remote-signing RPCs are SECURITY
# DEFINER and validate every token before doing anything.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...
