{
  "name": "sarke-sign",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Static web app for remote signature collection — receives a tokenized link from the Sarke mobile app, lets the recipient view inspection summary + PDF and sign on a canvas.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "signature_pad": "^5.0.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
