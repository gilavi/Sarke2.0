  "security": [{"apikey": [], "bearer": []}],
  "paths": {
    "/projects": {
      "get": {
        "summary": "List projects (RLS-scoped to authed user)",
        "tags": ["projects"],
        "responses": {"200": {"description": "Array of Project rows"}}
      },
      "post": {
        "summary": "Create a project",
        "tags": ["projects"],
        "responses": {"201": {"description": "Created"}}
      }
    },
    "/inspections": {
      "get": {
        "summary": "List inspections",
        "tags": ["inspections"],
        "responses": {"200": {"description": "Array of Inspection rows"}}
      }
    },
    "/templates": {
      "get": {
        "summary": "List templates (system + owned)",
        "tags": ["templates"],
        "responses": {"200": {"description": "Array of Template rows"}}
      }
    },
    "/certificates": {
      "get": {
        "summary": "List generated certificates",
        "tags": ["certificates"],
        "responses": {"200": {"description": "Array of Certificate rows"}}
      }
    },
    "/qualifications": {
      "get": {
        "summary": "List qualifications for the authed user",
        "tags": ["qualifications"],
        "responses": {"200": {"description": "Array of Qualification rows"}}
      }
    },
    "/remote_signing_requests": {
      "get": {
        "summary": "List async signer invitations",
        "tags": ["remote-signing"],
        "responses": {"200": {"description": "Array of RemoteSigningRequest rows"}}
      }
    }
  },
  "tags": [
    {"name": "projects"},
    {"name": "inspections"},
    {"name": "templates"},
    {"name": "certificates"},
    {"name": "qualifications"},
    {"name": "remote-signing"}
